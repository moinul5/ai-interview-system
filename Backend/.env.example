# Copy to .env and set values locally. Never commit secrets.

MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_interview_system

# Optional: full URL overrides the variables above when set (SQLAlchemy)
# DATABASE_URL=mysql+pymysql://root:pwd@localhost:3306/ai_interview_system

# Future: swap mock analyzer with real AI
OPENAI_API_KEY=

# Frontend dev (comma-separated origins for CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
